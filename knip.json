{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "exclude": ["unlisted"],
  "ignore": [
    "**/dist/**",
    "**/node_modules/**",
    "**/archive/**",
    "**/*.d.ts",
    "**/eslint.config.js",
    "**/webpack.*.js",
    "**/ecosystem.config.js"
  ],
  "ignoreFiles": [
    "apps/pubpay/src/service-worker.js",
    "apps/live/src/assets/index.ts",
    "apps/live/src/assets/images/index.ts",
    "packages/shared-types/src/common.ts",
    "packages/shared-types/src/lightning.ts",
    "packages/shared-types/src/nostr.ts"
  ],
  "ignoreDependencies": [
    "@types/*",
    "typescript",
    "eslint",
    "prettier",
    "webpack",
    "webpack-cli",
    "webpack-dev-server",
    "ts-loader",
    "css-loader",
    "style-loader",
    "mini-css-extract-plugin",
    "html-webpack-plugin",
    "copy-webpack-plugin",
    "@eslint/js",
    "@typescript-eslint/*",
    "husky",
    "lint-staged",
    "rimraf",
    "concurrently",
    "tsx",
    "buffer",
    "process"
  ],
  "ignoreIssues": {
    "apps/pubpay/src/stores/**": ["exports", "types"],
    "apps/pubpay/src/constants/**": ["exports"],
    "apps/pubpay/src/utils/**": ["exports", "types"],
    "apps/pubpay/src/types/**": ["types"],
    "apps/live/src/utils/domHelpers.ts": ["exports"],
    "apps/live/src/utils/errorHandling.ts": ["exports"],
    "apps/live/src/hooks/**": ["types"],
    "apps/live/src/services/**": ["types"],
    "apps/live/src/types/**": ["types"],
    "apps/live/src/utils/urlParser.ts": ["types"],
    "packages/shared-services/src/utils/validation.ts": ["exports"],
    "packages/shared-services/src/utils/nostrSchemas.ts": ["exports", "types"],
    "packages/shared-services/src/services/follow/FollowService.ts": [
      "duplicates"
    ],
    "packages/shared-services/src/utils/NostrUtil.ts": ["duplicates"],
    "packages/backend/src/services/**": ["types"]
  },
  "workspaces": {
    "apps/pubpay": {
      "entry": "src/index.tsx",
      "project": "src/**/*.{ts,tsx}",
      "ignoreDependencies": [
        "@tanstack/react-query",
        "@scure/bip32",
        "@scure/bip39"
      ]
    },
    "apps/live": {
      "entry": "src/index.tsx",
      "project": "src/**/*.{ts,tsx}",
      "ignoreDependencies": ["@scure/bip32", "@scure/bip39"]
    },
    "apps/jukebox": {
      "entry": "src/index.tsx",
      "project": "src/**/*.{ts,tsx}"
    },
    "packages/backend": {
      "entry": "src/index.ts",
      "project": "src/**/*.ts"
    },
    "packages/shared-services": {
      "entry": "src/index.ts",
      "project": "src/**/*.{ts,tsx}"
    },
    "packages/shared-ui": {
      "entry": "src/index.ts",
      "project": "src/**/*.{ts,tsx}"
    },
    "packages/shared-utils": {
      "entry": "src/index.ts",
      "project": "src/**/*.ts"
    },
    "packages/shared-types": {
      "entry": "src/index.ts",
      "project": "src/**/*.ts"
    }
  },
  "webpack": {
    "config": "tools/webpack/*.config.js"
  }
}
